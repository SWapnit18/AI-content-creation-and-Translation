# Environment Variables for AI Content Creation Backend

# Google Gemini AI API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# MongoDB Connection String
# For local MongoDB: mongodb://localhost:27017/ai-content-creation
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/ai-content-creation
MONGO_URI=mongodb://localhost:27017/ai-content-creation

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# AI Model Configuration
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=6144